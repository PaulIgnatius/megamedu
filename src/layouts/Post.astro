---
import Base from './Base.astro';
import Comments from '../components/Comments.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  authorRole: string;
  tags: string[];
}
const { title, description, pubDate, updatedDate, author, authorRole, tags } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const initial = author.trim().charAt(0).toUpperCase();
---
<Base title={`${title} — Pauls Workshop`} description={description}>
  <div class="wrap">
    <article>
      <header class="article-head">
        <p class="eyebrow">article</p>
        <h1>{title}</h1>
        <p class="lede muted">{description}</p>
        <div class="post-meta">
          <span>{fmt(pubDate)}</span>
          {updatedDate && <span>updated {fmt(updatedDate)}</span>}
          <span>by {author}</span>
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>

      <aside class="author-strip">
        <div class="avatar" aria-hidden="true">{initial}</div>
        <div>
          <strong>{author}</strong><br />
          <span class="muted">{authorRole}</span>
        </div>
      </aside>

      <Comments />
    </article>
  </div>

  <script>
    // Wrap every Shiki code block with a header bar: language label + copy button.
    document.querySelectorAll('.prose pre').forEach((pre) => {
      if (pre.parentElement?.classList.contains('code-block')) return;

      const lang = pre.getAttribute('data-language') ?? 'code';

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block';

      const bar = document.createElement('div');
      bar.className = 'code-block-bar';

      const label = document.createElement('span');
      label.textContent = lang;

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = 'Copy';
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code')?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(code);
          btn.textContent = 'Copied';
          setTimeout(() => (btn.textContent = 'Copy'), 1800);
        } catch {
          btn.textContent = 'Select & copy manually';
        }
      });

      bar.append(label, btn);
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.append(bar, pre);
    });
  </script>
</Base>
