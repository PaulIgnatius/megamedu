---
import Base from '../layouts/Base.astro';
---
<Base title="Work — Pauls Technical Services" description="Selected projects: Azure solutions, Copilot agents, and enterprise platform work.">
  <section class="hero" style="padding-bottom: 24px;">
    <div class="wrap">
      <p class="eyebrow">portfolio</p>
      <h1>Selected work</h1>
      <p class="lede muted">
        Real engagements, from requirements to running solution. Each project
        here typically has one or more companion articles in the blog.
      </p>
    </div>
  </section>

  <section class="section" style="border-top: none; padding-top: 24px;">
    <div class="wrap project-grid">
      <div class="project-card">
        <p class="stack">Azure · React · BRD · Proposal</p>
        <h3>Visitor Gate Pass Management System</h3>
        <p class="muted">
          Full design-and-delivery engagement for a cloud-based visitor
          management system: business requirements document, solution
          architecture on Azure, working React prototype, cost estimation,
          and a client-ready proposal and quotation.
        </p>
        <p class="muted"><strong>Role:</strong> Solution designer & developer</p>
      </div>

      <div class="project-card">
        <p class="stack">Microsoft 365 · Copilot · Governance</p>
        <h3>AI Administration & agent governance</h3>
        <p class="muted">
          Ongoing platform work inside an enterprise Microsoft 365 tenant:
          AI Administrator RBAC scope, Copilot Credits and licensing strategy,
          and governance with Entra Agent ID, Purview, and Defender.
        </p>
        <p class="muted"><strong>Role:</strong> AI Administrator</p>
      </div>

      <div class="project-card">
        <p class="stack">Copilot Studio · Agents SDK · Foundry</p>
        <h3>Agent build lab (in progress)</h3>
        <p class="muted">
          A structured build programme across declarative agents, custom
          engine agents, and Azure AI Foundry — documented step by step in
          the articles section as it happens.
        </p>
        <p class="muted"><strong>Role:</strong> Builder & author</p>
      </div>
    </div>
  </section>
</Base>
