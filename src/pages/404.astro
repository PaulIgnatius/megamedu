---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found — Pauls Education">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">404</p>
      <h1>This page doesn't exist.</h1>
      <p class="lede muted">The link may be old, or the article may have moved.</p>
      <div class="hero-actions">
        <a class="btn btn-solid" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/blog/">Browse articles</a>
      </div>
    </div>
  </section>
</Base>
